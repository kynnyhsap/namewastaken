{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "namewastaken-website",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-12",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
  },
  "vars": {
    "API_BASE_URL": "https://api.namewastaken.co",
  },
  "dev": {
    "port": 4040,
  },
}
