{
  "name": "namewastaken-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "cli": "bun --cwd packages/cli cli",
    "dev": "bun run dev:cloudflare",
    "dev:cli": "bun --cwd packages/cli dev",
    "dev:cloudflare": "turbo run dev --filter=@namewastaken/api --filter=@namewastaken/website --parallel",
    "dev:api": "turbo run dev --filter=@namewastaken/api",
    "dev:website": "turbo run dev --filter=@namewastaken/website",
    "build": "bun --cwd packages/cli build",
    "build:apps": "turbo run build --filter=@namewastaken/api --filter=@namewastaken/website",
    "build:types": "bun --cwd packages/cli build:types",
    "build:binary": "bun --cwd packages/cli build:binary",
    "test": "bun --cwd packages/cli test",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "fmt": "bun run format",
    "fmt:check": "bun run format:check",
    "lint": "oxlint .",
    "lint:type-aware": "oxlint --type-aware .",
    "lint:type-aware:check": "oxlint --type-aware --type-check .",
    "typecheck": "turbo run typecheck",
    "check:root": "bun run format:check",
    "check:workspaces": "turbo run check",
    "check": "bun run check:root && bun run check:workspaces"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@typescript/native-preview": "latest",
    "oxfmt": "^0.39.0",
    "oxlint": "^1.54.0",
    "oxlint-tsgolint": "^0.16.0",
    "turbo": "^2.8.0",
    "wrangler": "^4.8.0"
  },
  "packageManager": "bun@1.3.10"
}
